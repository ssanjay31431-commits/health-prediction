PORT=5000
MONGO_URI=your_mongo_connection_string
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.0

# JWT Authentication
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Email Configuration (Required for Resend email delivery)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
# When using a Resend account in test mode, set this to your verified Resend owner email.
# This allows the backend to retry a test-send to a verified owner address if an unverified recipient is blocked.
RESEND_OWNER_EMAIL=your_verified_resend_email@example.com
# A shared secret for testing email delivery without requiring auth.
# Set this to enable POST /api/email/test-public with header x-email-test-key.
EMAIL_TEST_KEY=your_secure_test_key

# Twilio WhatsApp Integration (optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+1234567890
